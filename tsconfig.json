{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],

    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"]
    },

    "incremental": true,
    "tsBuildInfoFile": "./.tscache/tsbuildinfo"
  },
  "include": ["src/**/*", "scripts/**/*", "tests/**/*"],
  // src/compile/entry.ts:B2 bun-compile 专属入口,静态 import 构建期生成的
  // assets-bundle.gen.json(.gitignore)→ tsc 在干净 checkout 下必 TS2307。
  // 仅排除该单文件;bundleAssets/unpackAssets 仍全量类型检查。
  "exclude": ["dist", "node_modules", ".harnessed", "vendor", "src/compile/entry.ts"]
}
