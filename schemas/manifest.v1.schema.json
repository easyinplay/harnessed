                  "type": "string"
                },
                "cmd": {
                  "minLength": 1,
                  "type": "string"
                },
                "cwd": {
                  "type": "string"
                },
                "env": {
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {
                      "type": "string"
                    }
                  }
                },
                "args": {
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {}
                  }
                },
                "git_ref": {
                  "minLength": 1,
                  "pattern": "^([a-f0-9]{7,40}|v?\\d+\\.\\d+\\.\\d+([.-][\\w.-]+)?)$",
                  "type": "string"
                },
                "idempotent_check": {
                  "minLength": 1,
                  "type": "string"
                },
                "marketplace_source": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "source",
                    "repo"
                  ],
                  "properties": {
                    "source": {
                      "const": "github",
                      "type": "string"
                    },
                    "repo": {
                      "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$",
                      "minLength": 3,
                      "type": "string"
                    }
                  }
                }
              }
            },
            {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "method",
                "cmd",
                "git_ref",
                "idempotent_check"
              ],
              "properties": {
                "method": {
                  "const": "git-clone-with-setup",
                  "type": "string"
                },
                "cmd": {
                  "minLength": 1,
                  "type": "string"
                },
                "cwd": {
                  "type": "string"
                },
                "env": {
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {
                      "type": "string"
                    }
                  }
                },
                "args": {
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {}
                  }
                },
                "git_ref": {
                  "minLength": 1,
                  "pattern": "^([a-f0-9]{7,40}|v?\\d+\\.\\d+\\.\\d+([.-][\\w.-]+)?)$",
                  "type": "string"
                },
                "idempotent_check": {
                  "minLength": 1,
                  "type": "string"
                }
              }
            },
            {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "method",
                "cmd",
                "npm_version",
                "idempotent_check"
              ],
              "properties": {
                "method": {
                  "const": "npx-skill-installer",
