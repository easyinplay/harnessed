              "type": "string"
            },
            "arbitration_rule": {
              "minLength": 1,
              "type": "string"
            },
            "override_signals": {
              "type": "array",
              "items": {
                "additionalProperties": false,
                "type": "object",
                "required": [
                  "phrase",
                  "use"
                ],
                "properties": {
                  "phrase": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "use": {
                    "minLength": 1,
                    "type": "string"
                  }
                }
              }
            },
            "do_not_use_when": {
              "minItems": 1,
              "type": "array",
              "items": {
                "minLength": 1,
                "type": "string"
              }
            },
            "if_rejected_use": {
              "minLength": 1,
              "type": "string"
            }
          }
        },
        "phase": {
          "anyOf": [
            {
              "const": "discuss",
              "type": "string"
            },
            {
              "const": "plan",
              "type": "string"
            },
            {
              "const": "execute",
              "type": "string"
            },
            {
              "const": "verify",
              "type": "string"
            }
          ]
        },
        "triggers": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "complexity_threshold": {
              "minimum": 1,
              "type": "integer"
            },
            "tdd_required": {
              "type": "boolean"
            },
            "brainstorming_required": {
              "type": "boolean"
            }
          }
        },
        "provides": {
          "minItems": 2,
          "uniqueItems": true,
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "id",
              "component_type"
