              "minLength": 1,
              "type": "string"
            },
            "cleanup_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "upstream_health": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "stability",
            "last_check",
            "last_known_good_version",
            "fallback_action"
          ],
          "properties": {
            "stability": {
              "anyOf": [
                {
                  "const": "stable",
                  "type": "string"
                },
                {
                  "const": "beta",
                  "type": "string"
                },
                {
                  "const": "unstable",
                  "type": "string"
                },
                {
                  "const": "archived",
                  "type": "string"
                }
              ]
            },
            "last_check": {
              "format": "date",
              "type": "string"
            },
            "last_known_good_version": {
              "minLength": 1,
              "type": "string"
            },
            "fallback_action": {
              "anyOf": [
                {
                  "const": "warn",
                  "type": "string"
                },
                {
                  "const": "block",
                  "type": "string"
                },
                {
                  "const": "use_alternative",
                  "type": "string"
                }
              ]
            },
            "alternative": {
              "type": "string"
            }
          }
