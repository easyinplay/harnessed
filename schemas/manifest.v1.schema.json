    "metadata": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "description",
        "upstream"
      ],
      "properties": {
        "name": {
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "minLength": 1,
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "maxLength": 120,
          "type": "string"
        },
        "upstream": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "source",
            "homepage",
            "repository",
            "license",
            "notice"
