            "source": {
              "minLength": 1,
              "type": "string"
            },
            "homepage": {
              "format": "uri",
              "type": "string"
            },
            "repository": {
              "format": "uri",
              "type": "string"
            },
            "license": {
              "anyOf": [
                {
                  "const": "MIT",
                  "type": "string"
                },
                {
                  "const": "Apache-2.0",
                  "type": "string"
                },
                {
                  "const": "BSD-3-Clause",
                  "type": "string"
                },
                {
                  "const": "ISC",
                  "type": "string"
                },
                {
                  "const": "0BSD",
                  "type": "string"
                },
                {
                  "const": "MIT-0",
                  "type": "string"
                },
                {
                  "const": "anthropics-official",
                  "type": "string"
                }
              ]
            },
            "license_source": {
              "anyOf": [
                {
                  "const": "README",
                  "type": "string"
                },
                {
                  "const": "registry",
                  "type": "string"
                },
                {
                  "const": "none",
                  "type": "string"
                },
                {
                  "const": "anthropics-official",
                  "type": "string"
                }
              ]
            },
            "notice": {
              "minLength": 1,
              "maxLength": 500,
              "type": "string"
            }
          }
        }
      }
    },
    "spec": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "component_type",
        "install",
        "verify",
        "uninstall",
        "upstream_health",
        "signed_by",
        "platforms",
        "category",
        "install_type"
