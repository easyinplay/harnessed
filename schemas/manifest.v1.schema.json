                  "type": "string"
                },
                "env": {
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {
                      "type": "string"
                    }
                  }
                },
                "args": {
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {}
                  }
                },
                "npm_version": {
                  "minLength": 1,
                  "type": "string"
                },
                "idempotent_check": {
                  "minLength": 1,
                  "type": "string"
                }
              }
            },
            {
              "additionalProperties": false,
