{
  "name": "harnessed",
  "version": "4.27.0",
  "description": "AI coding harness package manager + composition orchestrator",
  "type": "module",
  "license": "Apache-2.0",
  "author": "easyinplay",
  "repository": {
    "type": "git",
    "url": "https://github.com/easyinplay/harnessed.git"
  },
  "homepage": "https://github.com/easyinplay/harnessed#readme",
  "bugs": "https://github.com/easyinplay/harnessed/issues",
  "keywords": [
    "claude-code",
    "ai-harness",
    "package-manager",
    "composition",
    "skill-pack",
    "mcp",
    "orchestrator"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.12.0",
  "bin": {
    "harnessed": "./dist/cli.mjs",
    "harnessed-inject-state": "./bin/harnessed-inject-state.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "manifests",
    "messages",
    "workflows",
    "routing",
    "config-templates",
    "schemas",
    "README.md",
    "LICENSE",
    "NOTICE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsc --noEmit && tsup",
    "build:schema": "node ./scripts/build-schema.mjs",
    "validate:schema": "node ./scripts/validate-schema.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "bench": "vitest bench --run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build:binary": "bun scripts/build-binary.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.142",
    "@clack/prompts": "^0.10.1",
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "commander": "^13.0.0",
    "diff": "^9.0.0",
    "expr-eval": "^2.0.2",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
